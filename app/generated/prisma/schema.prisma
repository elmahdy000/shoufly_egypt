generator client {
  provider      = "prisma-client-js"
  output        = "../app/generated/prisma"
  binaryTargets = ["native", "rhel-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
}

enum UserRole {
  CLIENT
  VENDOR
  ADMIN
  DELIVERY
}

enum RequestStatus {
  PENDING_ADMIN_REVISION
  OPEN_FOR_BIDDING
  BIDS_RECEIVED
  OFFERS_FORWARDED
  ORDER_PAID_PENDING_DELIVERY
  CLOSED_SUCCESS
  CLOSED_CANCELLED
  REJECTED
}

enum BidStatus {
  PENDING
  SELECTED
  ACCEPTED_BY_CLIENT
  REJECTED
  WITHDRAWN
}

enum DeliveryStatus {
  ORDER_PLACED
  VENDOR_PREPARING
  READY_FOR_PICKUP
  OUT_FOR_DELIVERY
  IN_TRANSIT
  DELIVERED
  FAILED_DELIVERY
  RETURNED
}

enum WithdrawalStatus {
  PENDING
  APPROVED
  REJECTED
}

enum TransactionType {
  ESCROW_DEPOSIT
  VENDOR_PAYOUT
  DELIVERY_PAYOUT
  ADMIN_COMMISSION
  REFUND
  WITHDRAWAL
  WALLET_TOPUP
}

enum NotificationType {
  NEW_REQUEST
  NEW_BID
  OFFER_RECEIVED
  BID_ACCEPTED
  DELIVERY_UPDATE
  DELIVERY_FAILED
  PAYMENT_RECEIVED
  REFUND_ISSUED
  REQUEST_DISPATCHED
  WALLET_TOPUP
  WITHDRAWAL_APPROVED
  WITHDRAWAL_REJECTED
  WITHDRAWAL_REQUESTED
  REQUEST_CANCELLED
}

model User {
  id            Int      @id @default(autoincrement())
  fullName      String
  email         String   @unique
  password      String
  phone         String?
  role          UserRole
  isActive      Boolean  @default(true)
  isVerified    Boolean  @default(false)
  isBlocked     Boolean  @default(false)
  walletBalance Decimal  @default(0) @db.Decimal(12, 2)
  fcmToken      String?
  cityId        Int?
  governorateId Int?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  city        City?        @relation(fields: [cityId], references: [id])
  governorate Governorate? @relation(fields: [governorateId], references: [id])

  clientRequests           Request[]           @relation("ClientRequests")
  vendorBids               Bid[]
  vendorCategories         VendorCategory[]
  transactions             Transaction[]
  notifications            Notification[]
  vendorWithdrawals        WithdrawalRequest[] @relation("VendorWithdrawals")
  adminReviewedWithdrawals WithdrawalRequest[] @relation("AdminWithdrawalReviews")
  assignedDeliveries       Request[]           @relation("DeliveryAgent")
  sentMessages             ChatMessage[]       @relation("SentMessages")
  receivedMessages         ChatMessage[]       @relation("ReceivedMessages")
  reviewsGiven             Review[]            @relation("ReviewsGiven")
  reviewsReceived          Review[]            @relation("ReviewsReceived")
  complaints               Complaint[]         @relation("UserComplaints")
  complaintsReceived       Complaint[]         @relation("ReportedUserComplaints")
  resolvedComplaints       Complaint[]         @relation("AdminResolvedComplaints")
  vendorBrands             VendorBrand[]

  @@index([email])
  @@index([role])
  @@index([phone])
  @@index([isActive, isVerified])
}

enum CategoryType {
  SERVICE // Technician goes to client (e.g. Plumbing)
  PRODUCT // Needs delivery agent (e.g. Spare parts)
  DIGITAL // Online/Remote execution (e.g. Tutoring)
}

model Category {
  id            Int          @id @default(autoincrement())
  name          String       @unique
  slug          String       @unique
  parentId      Int?
  requiresBrand Boolean      @default(false)
  brandType     String?
  type          CategoryType @default(SERVICE)
  createdAt     DateTime     @default(now())

  parent        Category?  @relation("CategoryToSubcategory", fields: [parentId], references: [id])
  subcategories Category[] @relation("CategoryToSubcategory")

  requests Request[]
  vendors  VendorCategory[]

  @@index([slug])
  @@index([parentId])
  @@index([brandType])
  @@index([type])
}

model Brand {
  id        Int      @id @default(autoincrement())
  name      String
  slug      String   @unique
  type      String
  logo      String?
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())

  vendors  VendorBrand[]
  requests Request[]

  @@index([type])
  @@index([slug])
}

model VendorBrand {
  id       Int   @id @default(autoincrement())
  vendorId Int
  brandId  Int
  vendor   User  @relation(fields: [vendorId], references: [id], onDelete: Cascade)
  brand    Brand @relation(fields: [brandId], references: [id], onDelete: Cascade)

  @@unique([vendorId, brandId])
  @@index([vendorId])
  @@index([brandId])
}

model VendorCategory {
  id         Int      @id @default(autoincrement())
  vendorId   Int
  categoryId Int
  vendor     User     @relation(fields: [vendorId], references: [id], onDelete: Cascade)
  category   Category @relation(fields: [categoryId], references: [id], onDelete: Cascade)

  @@unique([vendorId, categoryId])
  @@index([vendorId])
  @@index([categoryId])
}

model Request {
  id                      Int           @id @default(autoincrement())
  clientId                Int
  title                   String
  description             String
  categoryId              Int
  brandId                 Int?
  address                 String
  latitude                Decimal       @db.Decimal(10, 7)
  longitude               Decimal       @db.Decimal(10, 7)
  deliveryPhone           String
  notes                   String?
  status                  RequestStatus @default(PENDING_ADMIN_REVISION)
  selectedBidId           Int?          @unique
  qrCode                  String?
  assignedDeliveryAgentId Int?
  cityId                  Int?
  governorateId           Int?
  createdAt               DateTime      @default(now())
  updatedAt               DateTime      @updatedAt

  city        City?        @relation(fields: [cityId], references: [id])
  governorate Governorate? @relation(fields: [governorateId], references: [id])

  client           User               @relation("ClientRequests", fields: [clientId], references: [id], onDelete: Cascade)
  deliveryAgent    User?              @relation("DeliveryAgent", fields: [assignedDeliveryAgentId], references: [id], onDelete: SetNull)
  category         Category           @relation(fields: [categoryId], references: [id])
  brand            Brand?             @relation(fields: [brandId], references: [id], onDelete: SetNull)
  images           RequestImage[]
  bids             Bid[]
  deliveryTracking DeliveryTracking[]
  transactions     Transaction[]
  notifications    Notification[]
  review           Review?
  complaints       Complaint[]

  @@index([clientId])
  @@index([categoryId])
  @@index([brandId])
  @@index([status, categoryId])
  @@index([latitude, longitude])
  @@index([assignedDeliveryAgentId])
  @@index([createdAt])
}

model RequestImage {
  id        Int      @id @default(autoincrement())
  requestId Int
  filePath  String
  fileName  String
  mimeType  String
  fileSize  Int
  createdAt DateTime @default(now())

  request Request @relation(fields: [requestId], references: [id], onDelete: Cascade)

  @@index([requestId])
}

model Bid {
  id          Int       @id @default(autoincrement())
  requestId   Int
  vendorId    Int
  description String
  netPrice    Decimal   @db.Decimal(12, 2)
  clientPrice Decimal   @db.Decimal(12, 2)
  status      BidStatus @default(PENDING)
  adminNote   String?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  request Request    @relation(fields: [requestId], references: [id], onDelete: Cascade)
  vendor  User       @relation(fields: [vendorId], references: [id], onDelete: Cascade)
  images  BidImage[]

  @@unique([requestId, vendorId])
  @@index([requestId])
  @@index([vendorId])
  @@index([status])
  @@index([createdAt])
}

model BidImage {
  id        Int      @id @default(autoincrement())
  bidId     Int
  filePath  String
  fileName  String
  mimeType  String
  fileSize  Int
  createdAt DateTime @default(now())

  bid Bid @relation(fields: [bidId], references: [id], onDelete: Cascade)

  @@index([bidId])
}

model DeliveryTracking {
  id           Int            @id @default(autoincrement())
  requestId    Int
  status       DeliveryStatus
  latitude     Decimal?       @db.Decimal(10, 7)
  longitude    Decimal?       @db.Decimal(10, 7)
  speed        Decimal?       @db.Decimal(5, 2)
  note         String?
  locationText String?
  createdAt    DateTime       @default(now())

  request Request @relation(fields: [requestId], references: [id], onDelete: Cascade)

  @@index([requestId])
  @@index([status])
}

model Transaction {
  id          Int             @id @default(autoincrement())
  userId      Int
  requestId   Int?
  amount      Decimal         @db.Decimal(12, 2)
  type        TransactionType
  description String?
  metadata    Json?
  createdAt   DateTime        @default(now())

  user    User     @relation(fields: [userId], references: [id], onDelete: Restrict)
  request Request? @relation(fields: [requestId], references: [id], onDelete: SetNull)

  @@index([userId])
  @@index([requestId])
  @@index([type])
  @@index([createdAt])
}

model Notification {
  id        Int              @id @default(autoincrement())
  userId    Int
  type      NotificationType
  title     String
  message   String
  requestId Int?
  metadata  Json?
  isRead    Boolean          @default(false)
  createdAt DateTime         @default(now())

  user    User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  request Request? @relation(fields: [requestId], references: [id], onDelete: SetNull)

  @@index([userId, isRead])
  @@index([createdAt])
}

model ChatMessage {
  id         Int      @id @default(autoincrement())
  senderId   Int
  receiverId Int
  content    String   @db.Text
  requestId  Int?
  isRead     Boolean  @default(false)
  createdAt  DateTime @default(now())

  sender   User @relation("SentMessages", fields: [senderId], references: [id], onDelete: Cascade)
  receiver User @relation("ReceivedMessages", fields: [receiverId], references: [id], onDelete: Cascade)

  @@index([senderId])
  @@index([receiverId])
  @@index([createdAt])
}

model WithdrawalRequest {
  id           Int              @id @default(autoincrement())
  vendorId     Int
  amount       Decimal          @db.Decimal(12, 2)
  status       WithdrawalStatus @default(PENDING)
  reviewNote   String?
  reviewedById Int?
  reviewedAt   DateTime?
  createdAt    DateTime         @default(now())
  updatedAt    DateTime         @updatedAt

  vendor     User  @relation("VendorWithdrawals", fields: [vendorId], references: [id], onDelete: Restrict)
  reviewedBy User? @relation("AdminWithdrawalReviews", fields: [reviewedById], references: [id], onDelete: SetNull)

  @@index([vendorId])
  @@index([status])
  @@index([reviewedById])
  @@index([createdAt])
}

model PlatformSetting {
  id                    Int      @id @default(autoincrement())
  commissionPercent     Decimal  @default(15) @db.Decimal(5, 2)
  minVendorMatchCount   Int      @default(3)
  initialRadiusKm       Int      @default(5)
  maxRadiusKm           Int      @default(50)
  radiusExpansionStepKm Int      @default(5)
  updatedAt             DateTime @updatedAt
}

model Review {
  id         Int      @id @default(autoincrement())
  requestId  Int      @unique
  reviewerId Int
  reviewedId Int
  rating     Int
  comment    String?
  createdAt  DateTime @default(now())

  request  Request @relation(fields: [requestId], references: [id], onDelete: Cascade)
  reviewer User    @relation("ReviewsGiven", fields: [reviewerId], references: [id], onDelete: Cascade)
  reviewed User    @relation("ReviewsReceived", fields: [reviewedId], references: [id], onDelete: Cascade)

  @@index([reviewedId])
}

model Complaint {
  id           Int             @id @default(autoincrement())
  requestId    Int
  userId       Int
  subject      String
  description  String
  status       ComplaintStatus @default(OPEN)
  resolution   String?
  resolvedById Int?
  resolvedAt   DateTime?
  createdAt    DateTime        @default(now())
  updatedAt    DateTime        @updatedAt

  request      Request @relation(fields: [requestId], references: [id], onDelete: Cascade)
  user         User    @relation("UserComplaints", fields: [userId], references: [id], onDelete: Cascade)
  reportedUser User?   @relation("ReportedUserComplaints", fields: [reportedUserId], references: [id], onDelete: SetNull)
  resolvedBy   User?   @relation("AdminResolvedComplaints", fields: [resolvedById], references: [id], onDelete: SetNull)

  reportedUserId Int?

  @@index([requestId])
  @@index([userId])
  @@index([reportedUserId])
  @@index([status])
}

enum ComplaintStatus {
  OPEN
  IN_PROGRESS
  RESOLVED
  REJECTED
}

model Governorate {
  id       Int       @id @default(autoincrement())
  name     String    @unique
  cities   City[]
  users    User[]
  requests Request[]
}

model City {
  id            Int         @id @default(autoincrement())
  name          String
  governorateId Int
  governorate   Governorate @relation(fields: [governorateId], references: [id])
  users         User[]
  requests      Request[]

  @@index([governorateId])
}
